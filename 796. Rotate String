class Solution {
public:
    bool rotateString(string s, string goal) {
        if(s.length()!=goal.length()){
            return false;
        }
        for(int i =0;i<s.length();i++){
            string result = s.substr(i)+s.substr(0,i);
            if(result==goal) return true;
        }
        return false;
    }
};
