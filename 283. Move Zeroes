class Solution {
public:
    void moveZeroes(vector<int>& nums) {
        vector<int>ans;
        int zerocount =0;
        for(int i =0;i<nums.size();i++){
            if(nums[i]!=0){
                ans.push_back(nums[i]);
            }
            else{
                zerocount++;
            }
        }
        while(zerocount--){
            ans.push_back(0);
        }
        nums = ans;
    }
};
