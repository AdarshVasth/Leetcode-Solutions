class Solution {
public:
    int singleNumber(vector<int>& nums) {
        int n = nums.size();

        for(int i = 0; i < n; i++) {
            int n1 = nums[i];
            int count = 0;

            for(int j = 0; j < n; j++) {
                if(nums[j] == n1) {
                    count++;
                }
            }

            if(count == 1) {
                return n1;
            }
        }

        return -1;
    }
};
